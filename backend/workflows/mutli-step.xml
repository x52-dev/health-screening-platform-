<?xml version="1.0" encoding="UTF-8"?>
<workflow id="multi-step-anemia" version="2.0">
    <steps>
        <!-- Form Step 1 -->
        <step id="demographics" type="form" next="clinical_signs">
            <field id="patient_age" type="number" required="true" label="Patient Age" />
            <field id="patient_gender" type="text" required="true" label="Biological Gender" />
        </step>

        <!-- Form Step 2 (Chained) -->
        <step id="clinical_signs" type="form" next="ai_eval">
            <field id="pallor" type="text" required="true" label="Pallor Level ('severe', 'normal', or 'uncertain')" />
            <field id="hb_level" type="number" required="false" label="Hemoglobin (g/dL)" />
        </step>

        <!-- AI Evaluation -->
        <step id="ai_eval" type="ai_screening">
            <model name="anemia_net" version_constraint="^1.2" />
            <inputs>
                <map from="pallor" to="pallor_feat" />
                <map from="patient_age" to="age_feat" />
            </inputs>
            <thresholds low_confidence="0.75" />
            <fallback action="manual_referral" message="AI confidence was too low." />
            <routing>
                <branch condition="result.label == 'severe'" next="outcome_urgent" />
                <default next="outcome_healthy" />
            </routing>
        </step>
    </steps>
    
    <outcomes>
        <outcome id="outcome_urgent" status="URGENT_REFERRAL" />
        <outcome id="outcome_healthy" status="DISCHARGE_HEALTHY" />
    </outcomes>
</workflow>