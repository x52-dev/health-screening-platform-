<?xml version="1.0" encoding="UTF-8"?>
<workflow id="anemia-v1" version="1.0.0">
    <steps>
        <step id="patient_inputs" type="form" next="ai_eval">
            <field id="pallor" type="select" required="true" label="Pallor Level" />
            <field id="hb" type="number" required="false" label="Hb (g/dL)" />
        </step>

        <!-- AI Step includes model, constraints, thresholds, and fallbacks -->
        <step id="ai_eval" type="ai_screening">
            <model name="anemia_net" version_constraint="^1.2" />
            <inputs>
                <map from="pallor" to="pallor_feat" />
            </inputs>
            <thresholds low_confidence="0.75" />
            <fallback action="manual_referral" message="AI uncertain. Route to clinical exam." />
            <routing>
                <branch condition="result.label == 'severe'" next="outcome_urgent" />
                <branch condition="result.label == 'mild'" next="outcome_monitor" />
                <default next="outcome_healthy" />
            </routing>
        </step>
    </steps>
    <outcomes>
        <outcome id="outcome_urgent" status="URGENT_REFERRAL" />
        <outcome id="outcome_monitor" status="MONITOR" />
        <outcome id="outcome_healthy" status="DISCHARGE" />
    </outcomes>
</workflow>