<?xml version="1.0" encoding="UTF-8"?>
<workflow id="legal_assistant_triage_engine">
    
    <!-- Stage 1: Broad Context Gathering -->
    <step id="case_intake" type="form" next="initial_jurisprudence_analysis">
        <field id="incident_description" type="text" required="true" label="Factual Description of Incident" />
        <field id="jurisdiction" type="text" required="true" label="Filing Jurisdiction" hint="e.g., Delhi High Court, NCLT" />
    </step>

    <!-- Stage 2: Top-Level Classification (AI Step 1) -->
    <ai_screening id="initial_jurisprudence_analysis">
        <model name="legal-reasoning-core" />
        <bindings>
            <input key="facts" ref="incident_description" />
            <input key="location" ref="jurisdiction" />
        </bindings>
        <routing>
            <branch when="civil_litigation" target="civil_details_form" />
            <branch when="criminal_defense" target="criminal_details_form" />
            <branch when="corporate_compliance" target="corporate_details_form" />
        </routing>
        <fallback threshold="0.90" target="human_attorney_review" />
    </ai_screening>

    <!-- Stage 3A: Civil Branch -->
    <step id="civil_details_form" type="form" next="civil_merit_eval">
        <field id="damages_sought" type="number" required="true" min="1" label="Estimated Damages (INR)" />
        <field id="contract_involved" type="text" required="true" label="Is there a signed contract? (Yes/No)" />
    </step>

    <!-- Stage 4A: Secondary AI Evaluation (Deep Dive) -->
    <ai_screening id="civil_merit_eval">
        <model name="legal-reasoning-core" />
        <!-- Passes both original intake data AND the new civil-specific data -->
        <bindings>
            <input key="facts" ref="incident_description" />
            <input key="damages" ref="damages_sought" />
            <input key="contract" ref="contract_involved" />
        </bindings>
        <routing>
            <branch when="high_probability_success" target="retainer_agreement_form" />
            <branch when="low_probability_success" target="decline_representation_path" />
        </routing>
    </ai_screening>

    <!-- Stage 3B: Criminal Branch (Isolated state path) -->
    <step id="criminal_details_form" type="form">
        <field id="charges_filed" type="text" required="true" label="Specific IPC Sections/Charges Filed" />
        <field id="bail_status" type="text" required="true" label="Current Bail Status" />
    </step>

</workflow>